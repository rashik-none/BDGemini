# ── MongoDB ──
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=autologinbot

# ── Telegram ──
TELEGRAM_BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here
ADMIN_USER_IDS=6196481482

# ── Gmail (only for legacy IMAP mode) ──
GMAIL_ACCOUNT=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Proxy / VPN (pick one) ──
# Single proxy:
# PROXY_URL=socks5://user:pass@host:port
# Multiple proxies (one per line, rotated per attempt):
# PROXY_LIST="socks5://u1:p1@host1:1080
#   socks5://u2:p2@host2:1080
#   http://u3:p3@host3:8080"

# ── Login worker tuning ──
LOGIN_MAX_RETRIES=2
DEVICE_PROMPT_TIMEOUT=90
LOGIN_NAVIGATION_TIMEOUT_MS=75000

# ── Economy ──
# REFERRAL_USERS_PER_CREDIT=10
# VERIFY_PRICE=1

# ── UI ──
BOT_TITLE=BDGeminBot
BOT_USERNAME=BDGeminBot
